<!-- ===================== JOBS HERO ===================== -->
<section class="page-hero">
    <div class="page-hero-shapes" aria-hidden="true">
      <i class="bi bi-briefcase"></i>
      <i class="bi bi-flower1"></i>
    </div>
    <div class="container">
      <h1>Job Opportunities</h1>
      <p>Build your career in agriculture. Explore open roles with AgroServices and our partner organizations.</p>
    </div>
  </section>

  <section class="jobs-section">
    <div class="container">

      <!-- ===================== FILTER BAR ===================== -->
      <div class="jobs-filter-bar">
        <div class="jobs-search">
          <i class="bi bi-search"></i>
          <input type="text" id="jobSearch" placeholder="Search job title...">
        </div>

        <div class="jobs-select-wrap">
          <i class="bi bi-geo-alt"></i>
          <select id="jobLocationFilter">
            <option value="all">All Locations</option>
            <option value="Dodoma Region">Dodoma Region</option>
            <option value="Dar es Salaam">Dar es Salaam</option>
            <option value="Remote">Remote</option>
            <option value="Mbeya Region">Mbeya Region</option>
          </select>
        </div>

        <div class="jobs-select-wrap">
          <i class="bi bi-briefcase"></i>
          <select id="jobTypeFilter">
            <option value="all">All Types</option>
            <option value="Full-time">Full-time</option>
            <option value="Part-time">Part-time</option>
            <option value="Contract">Contract</option>
          </select>
        </div>
      </div>
      <!-- ===================== JOB LIST ===================== -->
      <div class="jobs-list" id="jobsList">

        <% if (jobs && jobs.length > 0) { %>
          <% jobs.forEach(job => { %>
            <div class="job-card" data-title="<%= job.title %>" data-location="<%= job.region %>" data-type="<%= job.job_type %>">
              <div class="job-icon"><i class="bi bi-flower2"></i></div>
              <div class="job-info">
                <h3><%= job.title %></h3>
                <div class="job-meta">
                  <span><i class="bi bi-geo-alt"></i> <%= job.region %></span>
                  <span><i class="bi bi-clock"></i> <%= job.job_type %></span>
                  <span><i class="bi bi-building"></i> <%= job.category %></span>
                </div>
              </div>
              <a href="/account/jobs/<%= job.id %>/apply" class="btn btn-filled job-apply">Apply Now</a>
            </div>
          <% }) %>
        <% } else { %>
          <p style="text-align:center; color: var(--text-muted); padding: 40px 0;">
            No job opportunities available right now. Please check back soon.
          </p>
        <% } %>

      </div>

      <!-- ===================== NO RESULTS ===================== -->
      <div class="jobs-empty" id="jobsEmpty">
        <i class="bi bi-search"></i>
        <h3>No matching positions</h3>
        <p>Try a different search term or clear the filters below.</p>
        <button type="button" class="btn btn-outline" id="clearJobFilters">Clear Filters</button>
      </div>

      <!-- ===================== WHY WORK WITH US ===================== -->
      <div class="jobs-why">
        <h2>Why Work With AgroServices</h2>
        <div class="jobs-why-grid">
          <div class="jobs-why-item">
            <i class="bi bi-heart"></i>
            <span>Meaningful, community-driven work</span>
          </div>
          <div class="jobs-why-item">
            <i class="bi bi-graph-up-arrow"></i>
            <span>Room to grow &amp; learn</span>
          </div>
          <div class="jobs-why-item">
            <i class="bi bi-geo-alt"></i>
            <span>Roles across Tanzania</span>
          </div>
          <div class="jobs-why-item">
            <i class="bi bi-people"></i>
            <span>Supportive, mission-led team</span>
          </div>
        </div>
      </div>

    </div>
  </section>

     