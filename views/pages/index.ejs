
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <h1 class="hero-title">
        Empowering Farmers.<br>
        <span class="text-accent">Growing</span> Together.
      </h1>
      <p class="hero-text">
        AgroServices connects farmers, experts, and opportunities to build a
        stronger agricultural community and sustainable future.
      </p>
      <div class="hero-actions">
        <a href="/register" class="btn btn-filled btn-lg">Join Our Network</a>
        <a href="/about" class="btn btn-outline-light btn-lg">Read More</a>
      </div>
    </div>

    <!-- Feature cards overlapping hero bottom edge -->
    <div class="container">
      <div class="feature-cards">
        <div class="feature-card">
          <div class="feature-icon"><i class="bi bi-person-badge"></i></div>
          <h3>Expert Support</h3>
          <p>Get guidance from agricultural experts</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="bi bi-mortarboard"></i></div>
          <h3>Training &amp; Capacity</h3>
          <p>Improve your skills with our training programs</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
          <h3>Market Access</h3>
          <p>Access better markets and opportunities</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon"><i class="bi bi-people"></i></div>
          <h3>Community Network</h3>
          <p>Connect and grow with fellow farmers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="services">
    <div class="container">
      <div class="section-heading">
        <h2>Services We Offer</h2>
        <i class="bi bi-flower2 heading-divider"></i>
      </div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon"><i class="bi bi-mortarboard-fill"></i></div>
          <h3>Training Programs</h3>
          <p>Build your skills with practical and modern agriculture training.</p>
        </div>
        <div class="service-card">
          <div class="service-icon"><i class="bi bi-clipboard2-pulse-fill"></i></div>
          <h3>Advisory Services</h3>
          <p>Get expert advice for better farm productivity and yield.</p>
        </div>
        <div class="service-card">
          <div class="service-icon"><i class="bi bi-box-seam-fill"></i></div>
          <h3>Input Supply</h3>
          <p>Access quality inputs and farm supplies at affordable prices.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- =====================================================================
         LATEST NEWS & EVENTS - Pure CSS, matches your screenshot exactly
    ====================================================================== -->
    <div class="news-events-section">
      <div class="news-events-grid">

        <!-- LEFT: LATEST NEWS -->
        <div class="news-column">
          <h2 class="section-heading">LATEST NEWS</h2>

          <% 
            // Safe defaults to prevent errors if variables are missing
            let newsItems = latestNews || [];
            let eventItems = upcomingEvents || [];
          %>

          <% if (newsItems.length > 0) { %>
            <% newsItems.forEach(item => { %>
              <div class="news-card">
                <% if (item.profile_image) { %>
                  <div class="news-image">
                    <img src="<%= item.profile_image %>" alt="<%= item.title %>" loading="lazy">
                  </div>
                <% } %>
                <div class="news-content">
                  <h3 class="news-title"><%= item.title %></h3>
                  <p class="news-text"><%= item.description.substring(0, 140) %>...</p>
                  <div class="news-footer">
                    <span class="news-date">
                      <%= new Date(item.news_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                    </span>
                    <a href="/news/<%= item.news_id %>" class="news-more">Read full update →</a>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="empty-message">No recent news posted yet.</div>
          <% } %>
        </div>

        <!-- RIGHT: EVENTS -->
        <div class="events-column">
          <h2 class="section-heading">EVENTS</h2>

          <% if (eventItems.length > 0) { %>
            <% eventItems.forEach(item => { %>
              <div class="event-card">
                <div class="event-badge">
                  <span class="event-day"><%= new Date(item.event_date).getDate() %></span>
                  <span class="event-month"><%= new Date(item.event_date).toLocaleString('default', { month: 'short' }) %></span>
                  <span class="event-year"><%= new Date(item.event_date).getFullYear() %></span>
                </div>
                <div class="event-content">
                  <h3 class="event-title"><%= item.title %></h3>
                  <p class="event-location">
                    <i class="bi bi-geo-alt-fill"></i> <%= item.location || 'Venue TBA' %>
                  </p>
                  <p class="event-text">
                    <%= item.description ? item.description.substring(0, 100) + '...' : 'Details coming soon' %>
                  </p>
                  <a href="/events/<%= item.event_id %>" class="event-link">View event →</a>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="empty-message">No upcoming events scheduled.</div>
          <% } %>
        </div>

      </div>
    </div>
    <!-- End of News & Events -->

  </div>
</section>
<!-- ===================== FAQ ===================== -->
<section class="faq-home-section">
  <div class="container">
    <div class="faq-home-header">
      <div class="eyebrow">FAQ</div>
      <h2>Frequently Asked Questions</h2>
      <p>Everything you need to know about joining and using AgroServices.</p>
    </div>

    <div class="faq-home-list" id="faqHomeList">

      <div class="faq-home-item is-open">
        <button type="button" class="faq-home-question" aria-expanded="true">
          <span>How do I become a member of AgroServices?</span>
          <span class="faq-home-icon"><i class="bi bi-dash"></i></span>
        </button>
        <div class="faq-home-answer">
          <p>Click "Register" in the navigation bar and follow the sign-up steps &mdash; create an account, choose a membership plan, and complete payment before your account is activated.</p>
        </div>
      </div>

      <div class="faq-home-item">
        <button type="button" class="faq-home-question" aria-expanded="false">
          <span>Is there a cost to join?</span>
          <span class="faq-home-icon"><i class="bi bi-plus"></i></span>
        </button>
        <div class="faq-home-answer">
          <p>Yes, membership plans start at an affordable annual fee. Pricing and plan details are shown during registration.</p>
        </div>
      </div>

      <div class="faq-home-item">
        <button type="button" class="faq-home-question" aria-expanded="false">
          <span>How long does registration approval take?</span>
          <span class="faq-home-icon"><i class="bi bi-plus"></i></span>
        </button>
        <div class="faq-home-answer">
          <p>Most registrations are reviewed and approved within 24 hours of submitting your payment proof.</p>
        </div>
      </div>

      <div class="faq-home-item">
        <button type="button" class="faq-home-question" aria-expanded="false">
          <span>Do you offer training for beginners?</span>
          <span class="faq-home-icon"><i class="bi bi-plus"></i></span>
        </button>
        <div class="faq-home-answer">
          <p>Yes &mdash; our Guidance &amp; Training programs include beginner-level courses in crop production, livestock, agribusiness, and financial literacy.</p>
        </div>
      </div>

      <div class="faq-home-item">
        <button type="button" class="faq-home-question" aria-expanded="false">
          <span>Can I access AgroServices from anywhere in Tanzania?</span>
          <span class="faq-home-icon"><i class="bi bi-plus"></i></span>
        </button>
        <div class="faq-home-answer">
          <p>Yes, AgroServices is available online across Tanzania, with field officers supporting several regions in person.</p>
        </div>
      </div>

    </div>

    <div class="faq-home-footer">
      <span>Still have questions?</span>
      <a href="/contact">Contact our team <i class="bi bi-arrow-right"></i></a>
    </div>
  </div>
</section>
