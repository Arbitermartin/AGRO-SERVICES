<section class="auth-page">
    <div class="container" style="max-width: 640px;">
      <%- messages() %>
  
      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
        <ul class="error-list" style="color:#c0392b; margin-bottom:20px;">
          <% errors.forEach(err => { %>
            <li><%= err.msg %></li>
          <% }) %>
        </ul>
      <% } %>
  
      <div class="step-card">
        <div class="step-header" style="text-align:center; margin-bottom: 20px;">
          <div class="step-number" style="margin: 0 auto 12px;"><i class="bi bi-send"></i></div>
          <h2>Apply for <%= job.title %></h2>
          <p><i class="bi bi-geo-alt"></i> <%= job.region %> &nbsp;•&nbsp; <i class="bi bi-clock"></i> <%= job.job_type %> &nbsp;•&nbsp; <i class="bi bi-building"></i> <%= job.category %></p>
        </div>
  
        <!-- ✅ Job description / qualifications -->
        <div class="job-description-box">
          <h4><i class="bi bi-card-checklist"></i> Job Description &amp; Qualifications</h4>
          <p><%= job.description %></p>
          <div class="job-description-dates">
            <span><i class="bi bi-calendar-check"></i> Posted: <%= new Date(job.start_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
            <span><i class="bi bi-calendar-x"></i> Apply by: <%= new Date(job.end_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
          </div>
        </div>
  
        <form action="/account/jobs/<%= job.id %>/apply" method="POST" enctype="multipart/form-data" class="auth-form" style="margin-top: 24px;">
  
          <div class="form-field">
            <label>Full Name</label>
            <div class="input-wrap">
              <i class="bi bi-person input-icon"></i>
              <input type="text" name="applicant_name" placeholder="Enter your full name" required>
            </div>
          </div>
  
          <div class="form-field">
            <label>Email</label>
            <div class="input-wrap">
              <i class="bi bi-envelope input-icon"></i>
              <input type="email" name="applicant_email" placeholder="Enter your email" required>
            </div>
          </div>
  
          <div class="form-row">
            <div class="form-field">
              <label>Phone Number</label>
              <div class="input-wrap">
                <i class="bi bi-telephone input-icon"></i>
                <input type="tel" name="applicant_phone" placeholder="Enter your phone number" required>
              </div>
            </div>
  
            <div class="form-field">
              <label>Years of Experience</label>
              <div class="input-wrap">
                <i class="bi bi-briefcase input-icon"></i>
                <input type="number" name="years_experience" min="0" max="60" placeholder="e.g. 3" required>
              </div>
            </div>
          </div>
  
          <div class="form-field">
            <label>Cover Letter / Why are you a good fit?</label>
            <div class="input-wrap" style="align-items:flex-start;">
              <i class="bi bi-card-text input-icon" style="margin-top: 12px;"></i>
              <textarea name="cover_letter" rows="5" placeholder="Tell us about your relevant experience and qualifications..." style="padding-left:44px;" required></textarea>
            </div>
          </div>
  
          <div class="form-field">
            <label>Upload CV / Resume</label>
            <div class="upload-area" id="cvUploadArea">
              <i class="bi bi-cloud-upload" style="font-size:2.2rem; color:var(--primary-green); display:block; margin-bottom:10px;"></i>
              <p>Tap to upload your CV<br><small>PDF or DOCX (max 5MB)</small></p>
              <input type="file" id="cvUpload" name="cv_file" accept=".pdf,.doc,.docx" style="display:none;" required>
            </div>
            <div id="cvUploadedFile" style="display:none; margin-top:8px; font-size:0.85rem; color:var(--primary-green);">
              <i class="bi bi-file-earmark-check"></i> <span id="cvFileName"></span>
            </div>
          </div>
  
          <button type="submit" class="btn btn-filled btn-block btn-lg" style="margin-top: 12px;">
            Submit Application
          </button>
  
          <div class="auth-switch" style="margin-top:20px;text-align:center;">
            <a href="/jobs"><i class="bi bi-arrow-left"></i> Back to Job Listings</a>
          </div>
  
        </form>
      </div>
  
    </div>
  </section>